diff --git a/browser/components/preferences/main.js b/browser/components/preferences/main.js
--- a/browser/components/preferences/main.js
+++ b/browser/components/preferences/main.js
@@ -1881,6 +1881,150 @@ var gHilalPane = {
         }
       }
     });
+
+    const hilalUiFixCheckbox = /** @type {HTMLInputElement|null} */ (
+      document.getElementById("hilalUiFixEnabled")
+    );
+    const hilalUiFixConnectToWindowCheckbox =
+      /** @type {HTMLInputElement|null} */ (
+        document.getElementById("hilalUiFixConnectToWindow")
+      );
+    const hilalUiFixCompactPaddingCheckbox =
+      /** @type {HTMLInputElement|null} */ (
+        document.getElementById("hilalUiFixCompactPadding")
+      );
+    const hilalUiFixDynamicSeparatorCheckbox =
+      /** @type {HTMLInputElement|null} */ (
+        document.getElementById("hilalUiFixDynamicSeparator")
+      );
+    const hilalUiFixBottomRoundedCheckbox =
+      /** @type {HTMLInputElement|null} */ (
+        document.getElementById("hilalUiFixBottomRounded")
+      );
+    const hilalUiFixCloseOnHoverCheckbox =
+      /** @type {HTMLInputElement|null} */ (
+        document.getElementById("hilalUiFixCloseOnHover")
+      );
+    const hilalUiFixSubOptionsContainer = document.getElementById(
+      "hilalUiFixSubOptions"
+    );
+
+    const updateHilalUiFixSubOptionsState = () => {
+      const enabled = hilalUiFixCheckbox ? hilalUiFixCheckbox.checked : true;
+      if (hilalUiFixSubOptionsContainer) {
+        if (enabled) {
+          hilalUiFixSubOptionsContainer.removeAttribute("disabled");
+        } else {
+          hilalUiFixSubOptionsContainer.setAttribute("disabled", "true");
+        }
+      }
+      if (hilalUiFixConnectToWindowCheckbox) {
+        hilalUiFixConnectToWindowCheckbox.disabled = !enabled;
+      }
+      if (hilalUiFixCompactPaddingCheckbox) {
+        hilalUiFixCompactPaddingCheckbox.disabled = !enabled;
+      }
+      if (hilalUiFixDynamicSeparatorCheckbox) {
+        hilalUiFixDynamicSeparatorCheckbox.disabled = !enabled;
+      }
+      if (hilalUiFixBottomRoundedCheckbox) {
+        hilalUiFixBottomRoundedCheckbox.disabled = !enabled;
+      }
+      if (hilalUiFixCloseOnHoverCheckbox) {
+        hilalUiFixCloseOnHoverCheckbox.disabled = !enabled;
+      }
+    };
+
+    if (hilalUiFixCheckbox) {
+      hilalUiFixCheckbox.checked = Services.prefs.getBoolPref(
+        "hilal.uifix.enabled",
+        true
+      );
+      hilalUiFixCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "hilal.uifix.enabled",
+          hilalUiFixCheckbox.checked
+        );
+        updateHilalUiFixSubOptionsState();
+      });
+    }
+
+    if (hilalUiFixConnectToWindowCheckbox) {
+      hilalUiFixConnectToWindowCheckbox.checked = Services.prefs.getBoolPref(
+        "userChrome.tab.connect_to_window",
+        true
+      );
+      hilalUiFixConnectToWindowCheckbox.addEventListener(
+        "command",
+        function () {
+          Services.prefs.setBoolPref(
+            "userChrome.tab.connect_to_window",
+            hilalUiFixConnectToWindowCheckbox.checked
+          );
+        }
+      );
+    }
+
+    if (hilalUiFixCompactPaddingCheckbox) {
+      hilalUiFixCompactPaddingCheckbox.checked = Services.prefs.getBoolPref(
+        "userChrome.tab.lepton_like_padding",
+        false
+      );
+      hilalUiFixCompactPaddingCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "userChrome.tab.lepton_like_padding",
+          hilalUiFixCompactPaddingCheckbox.checked
+        );
+        Services.prefs.setBoolPref(
+          "userChrome.tab.photon_like_padding",
+          !hilalUiFixCompactPaddingCheckbox.checked
+        );
+      });
+    }
+
+    if (hilalUiFixDynamicSeparatorCheckbox) {
+      hilalUiFixDynamicSeparatorCheckbox.checked = Services.prefs.getBoolPref(
+        "userChrome.tab.dynamic_separator",
+        false
+      );
+      hilalUiFixDynamicSeparatorCheckbox.addEventListener(
+        "command",
+        function () {
+          Services.prefs.setBoolPref(
+            "userChrome.tab.dynamic_separator",
+            hilalUiFixDynamicSeparatorCheckbox.checked
+          );
+        }
+      );
+    }
+
+    if (hilalUiFixBottomRoundedCheckbox) {
+      hilalUiFixBottomRoundedCheckbox.checked = Services.prefs.getBoolPref(
+        "userChrome.tab.bottom_rounded_corner",
+        false
+      );
+      hilalUiFixBottomRoundedCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "userChrome.tab.bottom_rounded_corner",
+          hilalUiFixBottomRoundedCheckbox.checked
+        );
+      });
+    }
+
+    if (hilalUiFixCloseOnHoverCheckbox) {
+      hilalUiFixCloseOnHoverCheckbox.checked = Services.prefs.getBoolPref(
+        "userChrome.tab.close_button_at_hover",
+        true
+      );
+      hilalUiFixCloseOnHoverCheckbox.addEventListener("command", function () {
+        Services.prefs.setBoolPref(
+          "userChrome.tab.close_button_at_hover",
+          hilalUiFixCloseOnHoverCheckbox.checked
+        );
+      });
+    }
+
+    updateHilalUiFixSubOptionsState();
   },
 };
 

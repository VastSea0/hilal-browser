diff --git a/browser/components/sidebar/sidebar-main.css b/browser/components/sidebar/sidebar-main.css
--- a/browser/components/sidebar/sidebar-main.css
+++ b/browser/components/sidebar/sidebar-main.css
@@ -547,6 +547,172 @@
   text-align: start;
 }
 
+@media -moz-pref("hilal.tahoe.enabled") {
+@media (-moz-platform: macos) {
+  :host([hilal-sidebar]) {
+    --hilal-sidebar-muted: color-mix(in srgb, var(--hilal-sidebar-text) 62%, transparent);
+    --hilal-sidebar-faint: light-dark(rgba(0, 0, 0, 0.04), rgba(255, 255, 255, 0.05));
+    --hilal-sidebar-hover: light-dark(rgba(0, 0, 0, 0.05), rgba(255, 255, 255, 0.06));
+    --hilal-sidebar-highlight: light-dark(rgba(0, 0, 0, 0.08), rgba(255, 255, 255, 0.08));
+    --hilal-sidebar-highlight-text: var(--hilal-sidebar-text);
+    --hilal-sidebar-blue: light-dark(#0a84ff, #64a7ff);
+    --hilal-sidebar-border: transparent;
+    inline-size: 356px;
+    max-inline-size: 356px;
+    min-inline-size: 356px;
+  }
+
+  :host([hilal-sidebar]:not([vertical-tabs])) {
+    inline-size: 356px;
+    max-inline-size: 356px;
+    min-inline-size: 356px;
+  }
+
+  .hilal-sidebar-layout {
+    background: transparent;
+    padding-block-start: var(--hilal-sidebar-top-padding, 82px);
+  }
+
+  .hilal-sidebar-layout::before {
+    border-bottom: 0;
+  }
+
+  .hilal-workspace-rail {
+    display: none;
+  }
+
+  .hilal-workspace-list {
+    gap: 9px;
+  }
+
+  .hilal-workspace-button,
+  #hilal-workspace-add {
+    block-size: 36px;
+    border-radius: 11px;
+    flex-basis: 36px;
+    inline-size: 36px;
+    transition:
+      background-color 0.16s ease,
+      border-color 0.16s ease,
+      transform 0.12s ease;
+  }
+
+  .hilal-workspace-button:hover,
+  #hilal-workspace-add:hover {
+    transform: translateY(-0.5px);
+  }
+
+  .hilal-workspace-active {
+    background: var(--hilal-sidebar-highlight);
+    border-color: color-mix(in srgb, var(--hilal-sidebar-blue) 24%, transparent);
+    box-shadow:
+      0 1px 0 light-dark(rgba(255, 255, 255, 0.5), rgba(255, 255, 255, 0.08)) inset,
+      0 6px 16px color-mix(in srgb, var(--hilal-sidebar-blue) 18%, transparent);
+  }
+
+  #hilal-workspace-add {
+    border-style: solid;
+    color: var(--hilal-sidebar-muted);
+  }
+
+  .hilal-sidebar-panel {
+    padding: 0 13px 0 26px;
+  }
+
+  .hilal-panel-header {
+    position: absolute;
+    top: 22px;
+    right: 12px;
+    z-index: 12;
+    justify-content: flex-end;
+    gap: 6px;
+    min-block-size: 32px;
+    margin: 0;
+  }
+
+  .hilal-panel-workspace-icon,
+  .hilal-panel-title {
+    display: none;
+  }
+
+  .hilal-icon-button {
+    block-size: 30px;
+    border-radius: 999px;
+    inline-size: 30px;
+  }
+
+  #hilal-sidebar-search {
+    background: var(--hilal-sidebar-faint);
+    border-color: color-mix(in srgb, var(--hilal-sidebar-text) 10%, transparent);
+    border-radius: 999px;
+    min-block-size: 30px;
+    padding-inline: 10px;
+  }
+
+  #hilal-sidebar-search:focus {
+    border-color: color-mix(in srgb, var(--hilal-sidebar-blue) 34%, transparent);
+    box-shadow: 0 0 0 3px color-mix(in srgb, var(--hilal-sidebar-blue) 16%, transparent);
+  }
+
+  .hilal-panel-scroll {
+    padding-block-end: 18px;
+    scrollbar-width: none;
+  }
+
+  .hilal-panel-scroll::-webkit-scrollbar {
+    display: none;
+  }
+
+  .hilal-section {
+    gap: 8px;
+    margin-block-end: 20px;
+  }
+
+  .hilal-section-heading {
+    color: var(--hilal-sidebar-muted);
+    font-size: 13px;
+    font-weight: 700;
+    min-block-size: 26px;
+    padding-inline: 0 8px;
+    text-transform: none;
+  }
+
+  .hilal-row,
+  .hilal-footer-row {
+    border-radius: 10px;
+  }
+
+  .hilal-row {
+    min-block-size: 28px;
+    padding-inline: 8px;
+  }
+
+  .hilal-footer-row {
+    min-block-size: 30px;
+    padding-inline: 9px;
+  }
+
+  .hilal-count-badge {
+    background: light-dark(rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.08));
+    border: 1px solid color-mix(in srgb, var(--hilal-sidebar-text) 8%, transparent);
+  }
+
+  .hilal-footer-group,
+  .hilal-sidebar-footer,
+  .hilal-workspace-add-wrap {
+    border-color: color-mix(in srgb, var(--hilal-sidebar-text) 10%, transparent);
+  }
+
+  #hilal-tabs-section {
+    min-height: 240px;
+  }
+
+  .hilal-tabstrip-container {
+    gap: 2px;
+  }
+}
+}
+
 .wrapper {
   display: grid;
   grid-template-rows: auto min-content min-content;

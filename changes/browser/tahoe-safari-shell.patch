+    opacity: 0.7;
+    margin-inline-end: 4px;
+    display: flex;
+    align-items: center;
+  }
+
+  .safari-row-audio:hover {
+    opacity: 1;
+  }
+
+  .safari-row-pin {
+    color: var(--hilal-sidebar-muted);
+    margin-inline-end: 4px;
+    display: flex;
+    align-items: center;
+  }
+
+  .safari-bookmarks-sublist {

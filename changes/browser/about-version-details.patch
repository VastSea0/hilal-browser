+function getHilalVersionLabel() {
+  let displayVersion = AppConstants.MOZ_APP_VERSION_DISPLAY;
+  let appVersion = Services.appinfo.version;
+  if (!appVersion || appVersion === displayVersion) {
+    return displayVersion;
+  }
+
+  let buildID = Services.appinfo.appBuildID;
+  let baseVersion = `Firefox ${appVersion}`;
+  if (buildID) {
+    baseVersion += `, build ${buildID}`;
+  }
+  return `${displayVersion} (${baseVersion})`;
+}
+
 init();

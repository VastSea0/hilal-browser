Hilal Browser: avoid libwebrtc unified-prefix collision on Windows

Two autogenerated libwebrtc moz.build files end up producing the same
Mozilla unified-source prefix because the prefix is derived from the
last 20 characters of the relsrcdir:

  modules/congestion_controller/goog_cc_scream_network_controller/
      goog_cc_scream_network_controller_gn
  modules/congestion_controller/scream/scream_network_controller_gn

Both yield "etwork_controller_gn" and therefore both generate a file
called Unified_cpp_etwork_controller_gn0.cpp. On Windows mozmake this
manifests as a missing make rule for xul.dll:

  No rule to make target '...\goog_cc_scream_network_controller_gn\
  Unified_cpp_etwork_controller_gn0.obj', needed by '.../xul.dll'

Each of the two directories only has a single source file, so the
unified-build optimisation is pointless here. Setting
FILES_PER_UNIFIED_FILE = 1 makes mozbuild compile the .cc directly and
sidesteps the prefix collision entirely.

---
 .../goog_cc_scream_network_controller_gn/moz.build | 2 ++
 .../scream/scream_network_controller_gn/moz.build  | 2 ++
 2 files changed, 4 insertions(+)

diff --git a/third_party/libwebrtc/modules/congestion_controller/goog_cc_scream_network_controller/goog_cc_scream_network_controller_gn/moz.build b/third_party/libwebrtc/modules/congestion_controller/goog_cc_scream_network_controller/goog_cc_scream_network_controller_gn/moz.build
--- a/third_party/libwebrtc/modules/congestion_controller/goog_cc_scream_network_controller/goog_cc_scream_network_controller_gn/moz.build
+++ b/third_party/libwebrtc/modules/congestion_controller/goog_cc_scream_network_controller/goog_cc_scream_network_controller_gn/moz.build
@@ -34,6 +34,8 @@ LOCAL_INCLUDES += [
     "/tools/profiler/public"
 ]
 
+FILES_PER_UNIFIED_FILE = 1
+
 UNIFIED_SOURCES += [
     "/third_party/libwebrtc/modules/congestion_controller/goog_cc_scream_network_controller/goog_cc_scream_network_controller.cc"
 ]
diff --git a/third_party/libwebrtc/modules/congestion_controller/scream/scream_network_controller_gn/moz.build b/third_party/libwebrtc/modules/congestion_controller/scream/scream_network_controller_gn/moz.build
--- a/third_party/libwebrtc/modules/congestion_controller/scream/scream_network_controller_gn/moz.build
+++ b/third_party/libwebrtc/modules/congestion_controller/scream/scream_network_controller_gn/moz.build
@@ -34,6 +34,8 @@ LOCAL_INCLUDES += [
     "/tools/profiler/public"
 ]
 
+FILES_PER_UNIFIED_FILE = 1
+
 UNIFIED_SOURCES += [
     "/third_party/libwebrtc/modules/congestion_controller/scream/scream_network_controller.cc"
 ]

+@media (-moz-platform: macos) {
+  :root[windowtype="navigator:browser"]:not([macOSNativeFullscreen]) {
+    background: transparent !important;
+  }
+
+  :root:not([macOSNativeFullscreen]) body {
+    background: var(--hilal-glass-window-background) !important;
+  }
+
+  :root[windowtype="navigator:browser"]:not([macOSNativeFullscreen]) #hilal-browser-background {
+    -moz-default-appearance: -moz-sidebar;
+    appearance: auto;
+    position: absolute;
+    inset: 0;
+    z-index: 0;
+    pointer-events: none;
+    overflow: hidden;
+    background: transparent;
+  }
+
+  :root[windowtype="navigator:browser"]:not([macOSNativeFullscreen]) #hilal-browser-background::after {
+    content: "";
+    position: absolute;
+    inset: 0;
+    background: var(--hilal-glass-window-background);

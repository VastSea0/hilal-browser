+      --newtab-background-color: transparent;
+      --newtab-background-color-secondary: light-dark(rgba(255, 255, 255, 0.82), rgba(42, 41, 49, 0.72));
+      --newtab-background-card: light-dark(rgba(255, 255, 255, 0.72), rgba(66, 65, 77, 0.62));

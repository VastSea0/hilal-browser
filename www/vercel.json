{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/update/:path*", "destination": "/api/update?path=:path*" },
    { "source": "/releases.json", "destination": "/api/releases" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

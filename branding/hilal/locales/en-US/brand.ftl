## Hilal Browser Brand
##
## Hilal must be treated as a brand.
##
## It cannot be:
## - Transliterated.
## - Translated.
##
## Declension should be avoided where possible, leaving the original
## brand unaltered in prominent UI positions.

-brand-shorter-name = Hilal
-brand-short-name = Hilal
-brand-shortcut-name = Hilal Browser
-brand-full-name = Hilal Browser
# This brand name can be used in messages where the product name needs to
# remain unchanged across different versions.
-brand-product-name = Hilal
-vendor-short-name = Hilal
trademarkInfo = { " " }

. "$topsrcdir/../mozconfigs/base"

ac_add_options --enable-linker=lld

if [ "${GITHUB_ACTIONS:-}" = "true" ]; then
  # Keep peak memory below the hosted runner limit and avoid generating
  # debug data that is not published by the release workflow.
  mk_add_options MOZ_MAKE_FLAGS="-j2"
  ac_add_options --disable-debug-symbols
fi
